import java.util.*;
public class Main
{
	public static void main(String[] args) {
		Scanner sc = new Scanner(System.in);
		int n =sc.nextInt();
		int arr[] = new int[n+1];
		for(int i=0; i<n; i++)
		    arr[i] = sc.nextInt();
		System.out.print("Enter position: ");
		int pos = sc.nextInt();
		if(pos<0 || pos>n)
		    System.out.println("Invalid");
		else{
		    for(int i=pos; i<n-1; i++)
		        arr[i]= arr[i+1];
		}
		for(int i=0; i<n-1; i++)
		    System.out.print(arr[i]+ " ");
	}
}
